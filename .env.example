# Server (Express)
PORT=5000
NODE_ENV=development

# CORS - Frontend URL (Next.js runs on port 3000)
CLIENT_URL=http://localhost:3000

# Frontend - Backend API URL (used by Next.js)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# JWT Authentication
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Database - Update with your PostgreSQL credentials
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/bemconnect?schema=public"
